rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /lotto_results/{drawId} {
      // Anyone can read lottery results
      allow read: if true;

      // Allow creating a new draw result only if it has all required fields,
      // numbers is exactly 6 elements, and drawNumber is an integer.
      // Update and delete are prohibited to preserve historical integrity.
      allow create: if request.resource.data.keys().hasAll(['drawNumber', 'date', 'numbers', 'bonus'])
        && request.resource.data.drawNumber is int
        && request.resource.data.numbers is list
        && request.resource.data.numbers.size() == 6;

      allow update, delete: if false;
    }
  }
}
